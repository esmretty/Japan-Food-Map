{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile and global preferences",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "User's email address"
        },
        "displayName": {
          "type": "string",
          "description": "User's display name"
        },
        "preferences": {
          "type": "object",
          "description": "User's filter preferences",
          "properties": {
            "selectedCuisines": {
              "type": "array",
              "items": { "type": "string" }
            },
            "selectedColors": {
              "type": "array",
              "items": { "type": "string" }
            },
            "selectedDays": {
              "type": "array",
              "items": { "type": "string" }
            },
            "requireAward": {
              "type": "boolean"
            },
            "requireHyakumeiten": {
              "type": "boolean"
            }
          }
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["email"]
    },
    "UserRestaurantData": {
      "title": "UserRestaurantData",
      "description": "User's personal data for a specific restaurant",
      "type": "object",
      "properties": {
        "visited": {
          "type": "boolean",
          "description": "Whether the user has visited this restaurant"
        },
        "wishlist": {
          "type": "boolean",
          "description": "Whether the user wants to visit this restaurant"
        },
        "rating": {
          "type": "number",
          "description": "User's personal rating (e.g., 1-5)"
        },
        "notes": {
          "type": "string",
          "description": "User's personal notes"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Stores user profiles and preferences"
    },
    "/users/{userId}/restaurants/{restaurantId}": {
      "schema": { "$ref": "#/entities/UserRestaurantData" },
      "description": "Stores user's personal data for specific restaurants"
    }
  }
}
