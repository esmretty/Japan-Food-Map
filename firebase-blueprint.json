{
  "entities": {
    "Restaurant": {
      "title": "Restaurant",
      "description": "Information about a restaurant in Tokyo",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the restaurant"
        },
        "name": {
          "type": "string",
          "description": "Name of the restaurant"
        },
        "score": {
          "type": "number",
          "description": "Tabelog score"
        },
        "cuisine": {
          "type": "string",
          "description": "Type of cuisine"
        },
        "url": {
          "type": "string",
          "description": "Tabelog URL"
        },
        "lat": {
          "type": "number",
          "description": "Latitude"
        },
        "lng": {
          "type": "number",
          "description": "Longitude"
        },
        "businessHours": {
          "type": "string",
          "description": "Business hours"
        },
        "awards": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Awards won by the restaurant"
        },
        "hyakumeiten": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Hyakumeiten awards"
        },
        "photos": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "URLs of restaurant photos"
        },
        "description": {
          "type": "string",
          "description": "Description of the restaurant"
        },
        "storeInfo": {
          "type": "object",
          "description": "Detailed store information"
        },
        "address": {
          "type": "string",
          "description": "Address of the restaurant"
        },
        "googleMapUrl": {
          "type": "string",
          "description": "Google Maps search URL"
        }
      },
      "required": ["id", "name", "lat", "lng"]
    },
    "TokyoLineFeature": {
      "title": "Tokyo Line Feature",
      "description": "GeoJSON feature for a Tokyo train line",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "id": { "type": "string" },
        "properties": { "type": "object" },
        "geometry": { "type": "object" }
      }
    },
    "TokyoStationFeature": {
      "title": "Tokyo Station Feature",
      "description": "GeoJSON feature for a Tokyo train station",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "id": { "type": "string" },
        "properties": { "type": "object" },
        "geometry": { "type": "object" }
      }
    }
  },
  "firestore": {
    "/restaurants/{restaurantId}": {
      "schema": "Restaurant",
      "description": "Collection of restaurants"
    },
    "/tokyoLines/{lineId}": {
      "schema": "TokyoLineFeature",
      "description": "Collection of Tokyo train line GeoJSON features"
    },
    "/tokyoStations/{stationId}": {
      "schema": "TokyoStationFeature",
      "description": "Collection of Tokyo train station GeoJSON features"
    }
  }
}
