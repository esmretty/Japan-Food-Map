rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isValidPreferences(prefs) {
      return prefs == null || (
        (prefs.keys().hasOnly(['selectedCuisines', 'minScore', 'maxScore', 'selectedDays', 'requireAward', 'requireHyakumeiten'])) &&
        (!('selectedCuisines' in prefs) || prefs.selectedCuisines is list) &&
        (!('minScore' in prefs) || prefs.minScore is number) &&
        (!('maxScore' in prefs) || prefs.maxScore is number) &&
        (!('selectedDays' in prefs) || prefs.selectedDays is list) &&
        (!('requireAward' in prefs) || prefs.requireAward is bool) &&
        (!('requireHyakumeiten' in prefs) || prefs.requireHyakumeiten is bool)
      );
    }

    function isValidUserProfile(data) {
      return data.keys().hasOnly(['email', 'displayName', 'preferences', 'updatedAt']) &&
             data.email is string &&
             (!('displayName' in data) || data.displayName is string) &&
             (!('preferences' in data) || isValidPreferences(data.preferences)) &&
             (!('updatedAt' in data) || data.updatedAt is string);
    }

    function isValidUserRestaurantData(data) {
      return data.keys().hasOnly(['visited', 'wishlist', 'favorite', 'wantToGo', 'rating', 'notes', 'updatedAt']) &&
             (!('visited' in data) || data.visited is bool) &&
             (!('wishlist' in data) || data.wishlist is bool) &&
             (!('favorite' in data) || data.favorite is bool) &&
             (!('wantToGo' in data) || data.wantToGo is bool) &&
             (!('rating' in data) || (data.rating is number && data.rating >= 0 && data.rating <= 5)) &&
             (!('notes' in data) || (data.notes is string && data.notes.size() <= 2000)) &&
             ('updatedAt' in data && data.updatedAt is string);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProfile(request.resource.data);
      allow update: if isOwner(userId) && isValidUserProfile(request.resource.data);
      
      match /preferences/{prefId} {
        allow read, write: if isOwner(userId);
      }

      match /restaurants/{restaurantId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidUserRestaurantData(request.resource.data);
        allow update: if isOwner(userId) && isValidUserRestaurantData(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}
