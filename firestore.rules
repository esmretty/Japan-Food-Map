rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: restaurants
    // Document ID: [restaurantId] (string)
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - score: number
    //   - cuisine: string
    //   - url: string
    //   - lat: number (required)
    //   - lng: number (required)
    //   - businessHours: string
    //   - awards: list
    //   - hyakumeiten: list
    //   - photos: list
    //   - description: string
    //   - storeInfo: map
    //   - address: string
    //   - googleMapUrl: string
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    // Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if user is an admin (Bootstrapped with user email)
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "retty.liu@gmail.com" && request.auth.token.email_verified == true);
    }

    // Validate required fields exist
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // Validate Restaurant
    function isValidRestaurant() {
      let data = request.resource.data;
      return hasRequiredFields(['id', 'name', 'lat', 'lng']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.lat is number &&
             data.lng is number &&
             (!('score' in data) || data.score is number) &&
             (!('cuisine' in data) || (data.cuisine is string && data.cuisine.size() < 100)) &&
             (!('url' in data) || (data.url is string && data.url.size() < 500)) &&
             (!('businessHours' in data) || (data.businessHours is string && data.businessHours.size() < 500)) &&
             (!('awards' in data) || data.awards is list) &&
             (!('hyakumeiten' in data) || data.hyakumeiten is list) &&
             (!('photos' in data) || data.photos is list) &&
             (!('description' in data) || (data.description is string && data.description.size() < 5000)) &&
             (!('storeInfo' in data) || data.storeInfo is map) &&
             (!('address' in data) || (data.address is string && data.address.size() < 500)) &&
             (!('googleMapUrl' in data) || (data.googleMapUrl is string && data.googleMapUrl.size() < 1000));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /restaurants/{restaurantId} {
      // Anyone can read the restaurant data (public map)
      allow read: if true;
      
      // Only admins can create/update/delete restaurants
      allow create: if isAdmin() && isValidRestaurant();
      allow update: if isAdmin() && isValidRestaurant();
      allow delete: if isAdmin();
    }

    match /tokyoLines/{lineId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /tokyoStations/{stationId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      
      match /preferences/{document=**} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
      
      match /restaurants/{document=**} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }
  }
}
